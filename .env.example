# Django
DJANGO_SECRET_KEY=change-me-generate-a-real-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-domain.com,137.184.229.140

# Database — MySQL (production) or sqlite (dev only)
DB_ENGINE=mysql
