{
  "name": "rmaa-login-app",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start:server": "node server/index.js",
    "test:db": "node --input-type=module --eval \"import('./server/db.js').then(m=>m.initDb()).then(m=>m.testDb ? m.testDb() : import('./server/db.js').then(d=>d.testDb())).catch(e=>{ console.error(e.message); process.exit(1); })\"",
    "start": "npm-run-all --parallel start:server dev"
  },
  "dependencies": {
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "docxtemplater": "^3.68.4",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.4",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "libreoffice-convert": "^1.8.1",
    "mssql": "^9.0.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "pizzip": "^3.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.17.0",
    "react-window": "^2.2.7",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "npm-run-all": "^4.1.5",
    "vite": "^5.4.0"
  }
}
